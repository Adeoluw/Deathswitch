# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_in_production_at_least_32_chars_long

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deathswitch

# Mantle
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
BACKEND_WALLET_PRIVATE_KEY=0x...
FACTORY_CONTRACT_ADDRESS=0x...

# Notifications (Gmail SMTP via Nodemailer)
# 1. Use a Gmail account (or create a free one for this project)
# 2. Enable 2-Step Verification on it
# 3. Go to https://myaccount.google.com/apppasswords and generate an "App Password"
# 4. Put the Gmail address below and the 16-char app password (no spaces)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=DeathSwitch

# Admin
ADMIN_EMAIL=admin@deathswitch.xyz
